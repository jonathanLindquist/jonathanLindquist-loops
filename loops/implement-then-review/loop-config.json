{
  "schemaVersion": 1,
  "loop": "implement-then-review",
  "paths": {
    "workflowConfig": "docs/agents/project-workflow.json",
    "ticketWorkflow": "docs/agents/ticket-workflow.md",
    "issueTracker": "docs/agents/issue-tracker.md",
    "agentInstructions": "AGENTS.md",
    "plansDir": "docs/plans",
    "loopDocsDir": "docs/agent-loops/implement-then-review",
    "loopRef": "docs/agent-loops/implement-then-review/loop-ref.json",
    "loopConfig": "docs/agent-loops/implement-then-review/loop-config.json",
    "runSummaryPathTemplate": "docs/agent-loops/implement-then-review/runs/{ticketId}/summary.md",
    "rawLogPathTemplate": "docs/agent-loops/implement-then-review/runs/{ticketId}/raw/"
  },
  "ticketSelection": {
    "source": "obsidian-kanban",
    "lane": "Backlog",
    "strategy": "top-card-only",
    "requiredTriageTag": "#ready-for-agent",
    "ifTopCardIsUnready": "stop",
    "ifCardAndPlanConflict": "stop"
  },
  "agents": {
    "model": "ephemeral-subagents",
    "implementationRole": "implement-jl-agent",
    "implementationSkill": "implement-jl",
    "reviewerRole": "review-jl-agent",
    "reviewSkill": "review-jl",
    "reviewScope": "review-jl-branch-diff"
  },
  "branching": {
    "baseBranch": "main",
    "branchNameTemplate": "codex/{ticketId}-{slug}",
    "worktreeMode": "isolated-ticket-worktree",
    "oneTicketPerBranch": true
  },
  "limits": {
    "verificationRepairAttempts": 3,
    "reviewFixCycles": 3
  },
  "checks": {
    "ticketVerificationItems": "required",
    "repoLocalChecks": "full-practical-suite",
    "changedFileSecretScan": "required"
  },
  "review": {
    "reviewTarget": "branch-diff-against-base",
    "requiresImplementationCommit": true,
    "repairPolicy": "bounded-review-fix-cycles",
    "blockingFindingsPolicy": "route-to-implementation-until-limit",
    "prDiscussionLookup": "not-applicable-without-pr"
  },
  "handoff": {
    "terminalStatus": "reviewed",
    "createPullRequest": false,
    "merge": false,
    "completeKanbanCard": false,
    "leaveBranchAndWorktreeForHuman": true
  },
  "failurePolicy": {
    "missingWorkflowDocs": "stop",
    "dirtyTargetCheckout": "stop",
    "unreadyTopBacklogCard": "stop",
    "repeatedVerificationFailure": "stop",
    "implementationCommitFailure": "stop",
    "reviewAgentFailure": "stop",
    "unresolvedBlockingReviewFindings": "stop",
    "onStop": "leave-ticket-out-of-completed-and-record-blocker"
  },
  "records": {
    "writeRunSummary": true,
    "commitRunSummary": false,
    "keepRawLogsLocal": true,
    "rawLogsGitignored": true,
    "finalReviewEvidenceLocation": "run-summary-and-controller-response"
  }
}
