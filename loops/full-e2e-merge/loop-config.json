{
  "schemaVersion": 1,
  "loop": "full-e2e-merge",
  "paths": {
    "workflowConfig": "docs/agents/project-workflow.json",
    "ticketWorkflow": "docs/agents/ticket-workflow.md",
    "issueTracker": "docs/agents/issue-tracker.md",
    "agentInstructions": "AGENTS.md",
    "plansDir": "docs/plans",
    "loopDocsDir": "docs/agent-loops/full-e2e-merge",
    "loopRef": "docs/agent-loops/full-e2e-merge/loop-ref.json",
    "loopConfig": "docs/agent-loops/full-e2e-merge/loop-config.json",
    "runSummaryPathTemplate": "docs/agent-loops/full-e2e-merge/runs/{ticketId}/summary.md",
    "rawLogPathTemplate": "docs/agent-loops/full-e2e-merge/runs/{ticketId}/raw/"
  },
  "ticketSelection": {
    "source": "obsidian-kanban",
    "lane": "Backlog",
    "strategy": "top-card-only",
    "requiredTriageTag": "#ready-for-agent",
    "ifTopCardIsUnready": "stop",
    "ifCardAndPlanConflict": "stop"
  },
  "agents": {
    "model": "ephemeral-subagents",
    "implementationRole": "implementation-agent",
    "reviewerRole": "reviewer-agent",
    "reviewScope": "spec-plus-standards"
  },
  "branching": {
    "baseBranch": "main",
    "branchNameTemplate": "codex/{ticketId}-{slug}",
    "worktreeMode": "isolated-ticket-worktree",
    "oneTicketPerBranch": true
  },
  "limits": {
    "verificationRepairAttempts": 3,
    "reviewFixCycles": 3
  },
  "checks": {
    "ticketVerificationItems": "required",
    "repoLocalChecks": "full-practical-suite",
    "prChecks": "required-if-configured",
    "allowNoCiWithExplicitNote": true,
    "changedFileSecretScan": "required"
  },
  "merge": {
    "authority": "agent-when-green",
    "method": "squash",
    "baseDriftPolicy": "rebase-onto-current-base",
    "rerunChecksAfterRebase": true,
    "deleteBranchAndWorktreeAfterMerge": true
  },
  "failurePolicy": {
    "missingWorkflowDocs": "stop",
    "missingGitHubAuth": "stop",
    "dirtyTargetCheckout": "stop",
    "unreadyTopBacklogCard": "stop",
    "repeatedVerificationFailure": "stop",
    "unresolvedBlockingReviewFindings": "stop",
    "mergeConflict": "stop",
    "onStop": "leave-ticket-out-of-completed-and-record-blocker"
  },
  "records": {
    "commitRunSummary": true,
    "keepRawLogsLocal": true,
    "rawLogsGitignored": true,
    "finalMergeEvidenceLocation": "pull-request-and-kanban-completion-note"
  }
}
